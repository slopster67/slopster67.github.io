<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} | {% endif %}slopster</title>
    <meta name="description" content="{{ description or 'slopster: independent internet menace, foul-mouthed web tinkerer, and a general stain on polite web design.' }}" />
    <link rel="stylesheet" href="/css/site.css" />
  </head>
  <body class="{% if page.url == '/' %}home{% else %}subpage{% endif %}">
    <div id="globalheader" class="slopster-clone">
      <ul id="globalnav">
        <li class="gn-slopster"><a href="/">slopster</a></li>
        <li><a href="/about/">about</a></li>
        <li><a href="/manifesto/">manifesto</a></li>
        <li><a href="/now/">now</a></li>
        <li><a href="/lab/">lab</a></li>
        <li><a href="/field-notes/">field notes</a></li>
        <li><a href="/links/">links</a></li>
        <li><a href="/cv/">cv</a></li>
      </ul>
      <div id="globalsearch">
        <form class="search" action="/links/" method="get">
          <div class="search-wrapper empty blurred">
            <span class="left"></span>
            <label for="sp-searchtext"><span class="prettyplaceholder">Search</span><input type="search" name="q" id="sp-searchtext" class="prettysearch applesearch" placeholder="search, sort of"></label>
            <span class="right"></span>
          </div>
        </form>
      </div>
    </div>

    {% if page.url == '/' %}
      {{ content | safe }}
    {% else %}
      <div id="container">
        <div id="main">
          <div id="content" class="subpage-content">
            {{ content | safe }}
          </div>
        </div>
      </div>
    {% endif %}

    <div id="homefooter">
      <div id="links">
        <p class="left">browse the <a href="/">home page</a>, poke around the <a href="/lab/">lab</a>, or rifle through the <a href="/field-notes/">notes</a>.</p>
        <ul class="piped right">
          <li><a href="/about/" class="first">About</a></li>
          <li><a href="/manifesto/">Manifesto</a></li>
          <li><a href="/now/">Now</a></li>
          <li><a href="/links/">Links</a></li>
          <li><a href="/cv/">CV</a></li>
          <li><a href="/i-love-water/">I LOVE WATER</a></li>
        </ul>
      </div>
      <div class="sosumi">
        <p class="copyright">Copyright © 2026 slopster. All rights reserved, unfortunately.</p>
        <ul class="piped">
          <li><a href="/manifesto/" class="first">Terms of Attitude</a></li>
          <li><a href="/about/">Who This Goblin Is</a></li>
        </ul>
      </div>
    </div>
  </body>
</html>
