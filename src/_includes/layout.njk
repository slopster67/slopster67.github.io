<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} | {% endif %}slopster</title>
    <meta name="description" content="{{ description or 'slopster: independent internet menace, foul-mouthed web tinkerer, and a general stain on polite web design.' }}" />
    <link rel="stylesheet" href="/css/site.css" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="wrap header-wrap">
          <a class="brand" href="/">slopster</a>
          <nav aria-label="Primary" class="site-nav">
            <a href="/"{% if page.url == '/' %} class="is-current" aria-current="page"{% endif %}>home</a>
            <a href="/about/"{% if page.url == '/about/' %} class="is-current" aria-current="page"{% endif %}>about</a>
            <a href="/manifesto/"{% if page.url == '/manifesto/' %} class="is-current" aria-current="page"{% endif %}>manifesto</a>
            <a href="/now/"{% if page.url == '/now/' %} class="is-current" aria-current="page"{% endif %}>now</a>
            <a href="/lab/"{% if page.url == '/lab/' %} class="is-current" aria-current="page"{% endif %}>lab</a>
            <a href="/field-notes/"{% if page.url == '/field-notes/' %} class="is-current" aria-current="page"{% endif %}>field notes</a>
            <a href="/links/"{% if page.url == '/links/' %} class="is-current" aria-current="page"{% endif %}>links</a>
            <a href="/cv/"{% if page.url == '/cv/' %} class="is-current" aria-current="page"{% endif %}>cv</a>
            <a href="/i-love-water/"{% if page.url == '/i-love-water/' %} class="is-current nav-water" aria-current="page"{% else %} class="nav-water"{% endif %}>I LOVE WATER</a>
          </nav>
        </div>
      </header>

      <main class="site-main wrap">
        {{ content | safe }}
      </main>

      <footer class="site-footer wrap">
        <div>
          <p class="footer-title">slopster dot internet</p>
          <p class="muted">apple-inspired glossy filth, minus the corporate lobotomy.</p>
        </div>
        <p class="muted footer-stamp">clean chrome, rude copy.</p>
      </footer>
    </div>
  </body>
</html>
